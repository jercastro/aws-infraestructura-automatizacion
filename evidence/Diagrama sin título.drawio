        <mxCell id="OQG2-2nelE1BMnJZTqgt-125" parent="1" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=12;fontStyle=0;container=1;pointerEvents=0;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud_alt;strokeColor=#232F3E;fillColor=default;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;" value="AWS Cloud" vertex="1">
          <mxGeometry height="190" width="510" x="860" y="610" as="geometry" />
        </mxCell>
        <mxCell id="OQG2-2nelE1BMnJZTqgt-126" parent="OQG2-2nelE1BMnJZTqgt-125" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="La arquitectura propuesta ofrece múltiples ventajas para la empresa, destacando una menor latencia para los usuarios ubicados en Chile gracias al despliegue principal en la región de Santiago. Además, incorpora mecanismos de alta disponibilidad mediante balanceo de carga y escalabilidad automática, permitiendo mantener el servicio operativo ante aumentos de demanda. La implementación de respaldos en Amazon S3 y la replicación de imágenes AMI hacia una región secundaria facilitan la recuperación ante fallos y la continuidad operacional. Asimismo, el uso de recursos escalables optimiza los costos de infraestructura, ya que permite ajustar la capacidad según las necesidades del negocio sin incurrir en gastos innecesarios." vertex="1">
          <mxGeometry height="170" width="480" x="15" y="10" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
